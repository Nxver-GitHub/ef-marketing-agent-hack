# Supabase project credentials (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feature flags
VITE_ENABLE_ORG_CHART=true

# Z.AI (OpenAI-compatible) — used by the graph chat copilot in Discover.
# Mirror the unprefixed ZAI_* values from .env.local (Vite only exposes VITE_*).
VITE_ZAI_API_KEY=
VITE_ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# External data sources (read server-side by scoring functions)
APIFY_TOKEN=
USPTO_API_KEY=
GITHUB_TOKEN=
CRUNCHBASE_API_KEY=
ANTHROPIC_API_KEY=

# Set to "true" to read prospects/scores/signals from src/lib/snapshot.json
# instead of Supabase. Demo perf: replaces ~12MB of per-load REST traffic
# with one cached fetch from the build asset. Re-run scripts/snapshot-supabase.mjs
# to refresh.
VITE_USE_SNAPSHOT=false
