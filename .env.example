# Supabase project credentials (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feature flags
VITE_ENABLE_ORG_CHART=true

# Backend chat API — points the GraphChat client at the FastAPI /chat
# endpoint. Local dev defaults to http://localhost:8000 if unset.
# Boot the backend with:
#   cd server/  &&  uv run --env-file .env uvicorn credence.api:app --port 8000
VITE_API_URL=http://localhost:8000

# Anthropic Claude — server-side only (used by the graph chat copilot).
# Set in .env.local at repo root. Never prefix with VITE_ — must not ship to browser.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# External data sources (read server-side by scoring functions)
APIFY_TOKEN=
GITHUB_TOKEN=
CRUNCHBASE_API_KEY=

# USPTO patent data — Open Data Portal (api.uspto.gov), required by
# server/credence/extractors/patents.py since the legacy PatentsView host
# (search.patentsview.org) returned NXDOMAIN as of 2026-04. Patent extraction
# is hard-gated: with neither variable set, find_patent_co_inventions() raises
# RuntimeError, which signals.py wraps into sources_failed: ["uspto"] per
# Contract 1 partial-results semantics. There is no fallback path — by design.
#
# Registration: data.uspto.gov requires ID.me identity verification (~15 min).
# Once your key lands, set BOTH:
#   USPTO_USE_ODP=1
#   USPTO_ODP_API_KEY=<key from data.uspto.gov>
USPTO_USE_ODP=
USPTO_ODP_API_KEY=

# Set to "true" to read prospects/scores/signals from src/lib/snapshot.json
# instead of Supabase. Demo perf: replaces ~12MB of per-load REST traffic
# with one cached fetch from the build asset. Re-run scripts/snapshot-supabase.mjs
# to refresh.
VITE_USE_SNAPSHOT=false
